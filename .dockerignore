# Keep the build context lean AND keep secrets/local state out of the image.
.git
.github
**/node_modules
**/.next
**/.turbo
**/dist
**/.vercel
# Never bake env into the image — runtime env is injected by the orchestrator.
.env
.env.*
!.env.example
**/*.log
.claude
.vscode
.idea
.DS_Store
# Large local-only migration dumps (gitignored anyway, but be explicit).
docs/migration/*.json
# Private company migration tooling, backups, and operational notes are
# intentionally available only in this working tree. Git ignores them, but
# Docker build contexts do not inherit .gitignore and the builder copies the
# entire context.
packages/etl
.local
private
# Local Dokploy helpers embed cluster credentials and must never enter an image
# layer, cache, or remote BuildKit context.
packages/db/src/scripts/dokploy-*.ts
coverage
playwright-report
test-results

# --- Core ---
NODE_ENV=development
APP_URL=http://localhost:3000
# Optional worker-to-web address for durable Flow commands (defaults to APP_URL).
INTERNAL_WEB_URL=http://localhost:3000

# --- Database (Postgres 16+) ---
# DATABASE_URL — runtime app traffic (DML-only role, FORCE RLS). Point at the PgBouncer
#   transaction pooler (port 6432) in shared/prod setups; direct 5432 is fine locally.
# SUPERADMIN_DATABASE_URL — cross-tenant / super-admin / ETL traffic (a dedicated BYPASSRLS
#   role). Lets the tenant RLS policy stay a single index-usable equality. If unset it falls
#   back to DATABASE_URL, which CANNOT bypass the no-OR policy — set it in any real deployment.
# MIGRATION_DATABASE_URL — migrations only; direct 5432 login that can SET ROLE to the
#   NOLOGIN DATABASE_OWNER_ROLE. Never expose this credential to web/worker containers.
DATABASE_URL=postgresql://beaconhs_app:beaconhs_app@localhost:5433/beaconhs
SUPERADMIN_DATABASE_URL=postgresql://beaconhs_super:beaconhs_super@localhost:5433/beaconhs
MIGRATION_DATABASE_URL=postgresql://beaconhs_migrator:beaconhs_migrator@localhost:5433/beaconhs
DATABASE_OWNER_ROLE=beaconhs_owner
DATABASE_BACKUP_ROLE=beaconhs_backup

# --- Redis (for BullMQ + sessions/cache) ---
REDIS_URL=redis://localhost:6380

# --- Auth (Better-Auth) ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
BETTER_AUTH_URL=http://localhost:3000
# Stable HMAC bearer capabilities for private attachment URLs (32+ random characters).
ATTACHMENT_CAPABILITY_SECRET=change-me-to-a-separate-long-random-string

# --- File storage (Cloudflare R2 / S3-compatible) ---
R2_ENDPOINT=http://localhost:9000
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=beaconhs-dev
R2_PRIVATE_BUCKET_CONFIRMED=false

# --- In-browser PowerPoint editor (Collabora Online) ---
# COLLABORA_URL — browser-reachable Collabora server (docker compose ships one
#   on 9980). Leave empty to disable PowerPoint editing; PPTX import, playback
#   and download keep working without it.
# COLLABORA_WOPI_URL — this app's base URL as reachable FROM the Collabora
#   container (WOPI callbacks). Local Docker needs host.docker.internal;
#   deployments can usually omit it (falls back to APP_URL).
COLLABORA_URL=http://localhost:9980
COLLABORA_WOPI_URL=http://host.docker.internal:3000

# --- Local email (Mailpit) ---
# Production providers are configured under Platform email (or per tenant)
# and their credentials are encrypted in PostgreSQL.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM="BeaconHS <noreply@beaconhs.local>"

# --- SMS (Twilio, critical alerts only) ---

# --- Web Push (VAPID) ---
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@beaconhs.app

# --- AI ---
# AI provider / model / API key are configured PER TENANT in the app
# (Admin → AI) and encrypted at rest. Nothing AI-related belongs in this file.

# --- Observability ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

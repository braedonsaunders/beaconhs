# --- Core ---
NODE_ENV=development
APP_URL=http://localhost:3000

# --- Database (Postgres 16+) ---
DATABASE_URL=postgresql://beaconhs:beaconhs@localhost:5432/beaconhs

# --- Redis (for BullMQ + sessions/cache) ---
REDIS_URL=redis://localhost:6379

# --- Auth (Better-Auth) ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
BETTER_AUTH_URL=http://localhost:3000

# --- File storage (Cloudflare R2 / S3-compatible) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=beaconhs-dev
R2_PUBLIC_URL=http://localhost:9000/beaconhs-dev

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM=noreply@beaconhs.app

# --- SMS (Twilio, critical alerts only) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# --- Web Push (VAPID) ---
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@beaconhs.app

# --- Observability ---
SENTRY_DSN=

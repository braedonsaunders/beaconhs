{
  "name": "@beaconhs/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts",
    "./rls": "./src/rls.ts",
    "./canonical-templates": "./src/canonical-templates.ts",
    "./seed/lift-plan-template": "./src/seed/lift-plan-template.ts",
    "./seed/pdf-templates": "./src/seed/pdf-templates.ts",
    "./seed/report-definitions": "./src/seed/report-definitions.ts"
  },
  "scripts": {
    "generate": "drizzle-kit generate",
    "migrate": "tsx --env-file=../../.env src/migrate.ts",
    "push": "drizzle-kit push",
    "push:ci": "drizzle-kit push --force",
    "studio": "drizzle-kit studio",
    "seed": "tsx --env-file=../../.env src/seed.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@appkit/reports": "file:../../vendor/appkit/appkit-reports-0.2.0-6ee2330.tgz",
    "@beaconhs/forms-core": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "tsx": "^4.23.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}

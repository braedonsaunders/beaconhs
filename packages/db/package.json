{
  "name": "@beaconhs/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts",
    "./rls": "./src/rls.ts",
    "./canonical-templates": "./src/canonical-templates.ts",
    "./seed/lift-plan-template": "./src/seed/lift-plan-template.ts"
  },
  "scripts": {
    "generate": "drizzle-kit generate",
    "migrate": "tsx --env-file=../../.env src/migrate.ts",
    "push": "drizzle-kit push",
    "studio": "drizzle-kit studio",
    "seed": "tsx --env-file=../../.env src/seed.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@beaconhs/forms-core": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}

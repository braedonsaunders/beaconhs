{
  "name": "@beaconhs/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "scheduler:dev": "tsx watch src/scheduler.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "scheduler:start": "node dist/scheduler.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@beaconhs/audit": "workspace:*",
    "@beaconhs/db": "workspace:*",
    "@beaconhs/emails": "workspace:*",
    "@beaconhs/events": "workspace:*",
    "@beaconhs/forms-core": "workspace:*",
    "@beaconhs/forms-pdf": "workspace:*",
    "@beaconhs/jobs": "workspace:*",
    "@beaconhs/plugin-sdk": "workspace:*",
    "@beaconhs/storage": "workspace:*",
    "bullmq": "^5.76.10",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.4.1",
    "twilio": "^5.3.5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/web-push": "^3.6.4",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}

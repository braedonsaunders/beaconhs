{
  "name": "@beaconhs/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "scheduler:dev": "tsx watch src/scheduler.ts",
    "build": "node build.mjs",
    "start": "node dist/index.js",
    "scheduler:start": "node dist/scheduler.js",
    "email-config:check": "tsx src/scripts/check-email-config.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@beaconhs/analytics": "workspace:*",
    "@beaconhs/audit": "workspace:*",
    "@beaconhs/compliance": "workspace:*",
    "@beaconhs/db": "workspace:*",
    "@beaconhs/email-render": "workspace:*",
    "@beaconhs/emails": "workspace:*",
    "@beaconhs/events": "workspace:*",
    "@beaconhs/forms-core": "workspace:*",
    "@beaconhs/forms-pdf": "workspace:*",
    "@beaconhs/integrations": "workspace:*",
    "@beaconhs/jobs": "workspace:*",
    "@beaconhs/office": "workspace:*",
    "@beaconhs/reports": "workspace:*",
    "@beaconhs/sms": "workspace:*",
    "@beaconhs/storage": "workspace:*",
    "@beaconhs/sync": "workspace:*",
    "@beaconhs/tenant": "workspace:*",
    "@sentry/node": "10.65.0",
    "bullmq": "^5.79.1",
    "cron-parser": "^4.9.0",
    "drizzle-orm": "^0.45.2",
    "qrcode": "^1.5.4",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/qrcode": "^1.5.6",
    "@types/web-push": "^3.6.4",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}

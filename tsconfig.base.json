{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    // Several active dependencies (Better Auth, Drizzle, Excalidraw/Fabric and
    // Next) publish declaration files for optional runtimes or incompatible
    // peer versions that fail under TypeScript 6. Application source is still
    // checked strictly; only third-party declaration internals are skipped.
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "incremental": true,
    "useDefineForClassFields": true
  },
  "exclude": ["node_modules", "dist", ".next", "build", "coverage"]
}
